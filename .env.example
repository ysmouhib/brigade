# ---- modes ----
# Offline demo (no API key, no Lean install): FAKE_LLM=1 LEAN_MODE=fake
FAKE_LLM=0
LEAN_MODE=file            # fake | file | repl

# ---- Anthropic ----
ANTHROPIC_API_KEY=sk-ant-...
CHEF_MODEL=claude-opus-4-8       # chef / strategist / critic
WORKER_MODEL=claude-sonnet-4-6   # brainstormers / formalizer / prover / skeptic / decomposer

# ---- Lean (after scripts/setup_lean.sh) ----
LEAN_PROJECT_DIR=./lean/BrigadeLean
LEAN_REPL_BIN=./lean/repl/.lake/build/bin/repl   # only for LEAN_MODE=repl
LEAN_TIMEOUT_S=180

# ---- proving power (see README "Proving power") ----
TACTIC_CASCADE=1            # try omega/ring/simp/... in one Lean call before any prover tokens
PROVE_SAMPLES=1             # parallel proof candidates on the first attempt (try 4 for real runs)
RETRIEVAL=off               # off | loogle | leansearch  (Mathlib premise retrieval, advisory only)
#PROVER_BASE_URL=http://localhost:8000/v1   # optional dedicated prover model (OpenAI-compatible)
#PROVER_MODEL=Goedel-LM/Goedel-Prover-V2-8B
#PROVER_API_KEY=

# ---- persistence ----
BRIGADE_DB=                 # e.g. jobs.db to keep finished jobs across restarts

# ---- budgets (per job; the app can lower/raise within clamps) ----
MAX_ROUNDS=2
N_BRAINSTORMERS=3
REPAIR_CYCLES=4
MAX_DEPTH=2
MAX_LEAN_CALLS=120
MAX_LLM_CALLS=200

# ---- server ----
PORT=8811
AUTH_TOKEN=                 # set to require "Authorization: Bearer <token>"
